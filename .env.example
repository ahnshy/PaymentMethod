# Toss Payments API 개별 연동 키
# 테스트 키는 Toss Payments 개발자센터에서 발급받으세요.
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_여기에_클라이언트키
TOSS_SECRET_KEY=test_sk_여기에_시크릿키

# PayPal Sandbox 연동 키
# PayPal Developer Dashboard에서 REST API App을 만들고 Client ID / Secret을 발급받으세요.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=여기에_페이팔_샌드박스_클라이언트_ID
PAYPAL_CLIENT_SECRET=여기에_페이팔_샌드박스_시크릿
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=KRW

# 배포 도메인. Vercel 배포 후 https://your-domain.vercel.app 형태로 설정하세요.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 카카오톡 결제 알림은 일반 KakaoTalk Message API가 아니라 알림톡/친구톡 사업자 API 사용을 권장합니다.
# 아래 값이 없으면 빌드와 테스트를 위해 mock 전송으로 처리합니다.
KAKAO_ALIMTALK_API_URL=
KAKAO_ALIMTALK_API_TOKEN=
KAKAO_ALIMTALK_SENDER_KEY=
KAKAO_ALIMTALK_TEMPLATE_CODE=
